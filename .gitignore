# Vendored dependencies
/vendor/

# Python virtual environments
.venv/
venv/
env/
ENV/

# Python cache / bytecode
__pycache__/
*.py[cod]
*$py.class

# Packaging / distribution
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# Test, coverage, and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Logs and local runtime files
*.log
*.out
*.err

# IDE / editor
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Optional local env files (keep secrets out of git)
.env
.env.*
!.env.example